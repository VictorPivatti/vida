{
  "name": "vida-dashboard",
  "version": "3.5.0",
  "description": "Dashboard assistencial single-file para UPA 24h",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.cjs",
    "dev": "esbuild src/js/app.js --bundle --servedir=src --outdir=src/.dev --format=esm --watch",
    "test": "npm run build && node harness.cjs index.html && node tests/metrics.test.cjs && node tests/parsers.test.cjs && node tests/integration.test.cjs && node tests/unit/utils.test.mjs && node tests/parsers.unit.test.mjs && node tests/metrics.unit.test.mjs",
    "smoke": "node harness.cjs index.html",
    "test:watch": "node -e \"const{execSync:e,watch}=require('fs');const run=()=>{try{e('npm test',{stdio:'inherit'})}catch(_){}};run();watch('.',{recursive:true},(t,f)=>{if(f&&(f.endsWith('.js')||f.endsWith('.html')))run();})\""
  },
  "dependencies": {
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
